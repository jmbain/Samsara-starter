# -----------------------------------------------------------------------
# Samsara-starter local development environment template
# Copy to .env and fill in values. Never commit .env to git.
# -----------------------------------------------------------------------

# Application
HTTP_PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
USE_SIMPLE=true

# Kafka (Confluent Cloud)
# Obtain from: wp/kafka/<customer> secret in AWS Secrets Manager (api_key / api_secret fields)
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
KAFKA_SASL_USERNAME=<api_key>
KAFKA_SASL_PASSWORD=<api_secret>
KAFKA_SSL=true
KAFKA_CONSUMER_GROUP_ID=samsara-consumer-dev

# Schema Registry (Confluent Cloud)
# Obtain from: wp/kafka secret (schema_registry_endpoint / schema_registry_api_key / schema_registry_api_secret)
KAFKA_SCHEMA_REGISTRY_HOST=https://psrc-xxxxx.us-east-2.aws.confluent.cloud
KAFKA_SCHEMA_REGISTRY_USERNAME=<sr_api_key>
KAFKA_SCHEMA_REGISTRY_PASSWORD=<sr_api_secret>

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/busie_dev

# AWS
AWS_REGION=us-east-1

# Samsara
# Dev shortcut: bypasses Secrets Manager for local development.
# In production this is fetched from busie/samsara/{customerId}/api_token in Secrets Manager.
SAMSARA_API_TOKEN=
